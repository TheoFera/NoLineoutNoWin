{
  "name": "no-lineout-no-win",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Jeu mobile tactique de touche au rugby - Phaser 3 + TypeScript + Capacitor.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "test:lot0": "node --experimental-strip-types --test tests/lot0.test.ts",
    "test:lot1": "node --experimental-strip-types --test tests/lot1.test.ts",
    "test:lot2": "node --experimental-strip-types --test tests/lot2.test.ts",
    "test:lot3": "node --experimental-strip-types --test tests/lot3.test.ts",
    "test:lot4": "node --experimental-strip-types --test tests/lot4.test.ts",
    "test:lot5": "node --experimental-strip-types --test tests/lot5.test.ts",
    "test:lot6": "node --experimental-strip-types --test tests/lot6.test.ts",
    "test:lot7": "node --experimental-strip-types --test tests/lot7.test.ts",
    "test:lot8": "node --experimental-strip-types --test tests/lot8.test.ts",
    "test:lot9": "node --experimental-strip-types --test tests/lot9.test.ts",
    "test:lot10": "node --experimental-strip-types --test tests/lot10.test.ts",
    "test:lot11": "node --experimental-strip-types --test tests/lot11.test.ts",
    "test:lot12": "node --experimental-strip-types --test tests/lot12.test.ts",
    "simulate:v2": "node --experimental-strip-types scripts/simulate-gameplay-v2.ts",
    "test": "npm run test:lot0 && npm run test:lot1 && npm run test:lot2 && npm run test:lot3 && npm run test:lot4 && npm run test:lot5 && npm run test:lot6 && npm run test:lot7 && npm run test:lot8 && npm run test:lot9 && npm run test:lot10 && npm run test:lot11 && npm run test:lot12",
    "preview": "vite preview --host 0.0.0.0",
    "cap:init": "npx cap init \"No Lineout No Win\" fr.nolineout.nowin --web-dir=dist",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "android": "npx cap open android",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "latest",
    "@capacitor/core": "latest",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@capacitor/cli": "latest",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
