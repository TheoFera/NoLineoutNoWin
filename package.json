{
  "name": "no-lineout-no-win",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Jeu mobile tactique de touche au rugby - Phaser 3 + TypeScript + Capacitor.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cap:init": "npx cap init \"No Lineout No Win\" fr.nolineout.nowin --web-dir=dist",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "android": "npx cap open android",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "latest",
    "@capacitor/core": "latest",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@capacitor/cli": "latest",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
